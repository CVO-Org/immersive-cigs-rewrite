<?xml version="1.0" encoding="utf-8"?>
<Project name="cigs_core">
    <Package name="CBASettings">
        <Key ID="STR_cigs_core_set_ace_arsenal_tab">
            <English>Enable Custom Category Tab in ACE Arsenal</English>
            <French>Activer les catégories personnalisées dans ACE Arsenal</French>
            <Japanese>ACE武器庫でカスタムされた分類を有効化</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_ace_arsenal_tab_desc">
            <English>When Enabled, this will create a Immersion Cig Tab in the ACE Arsenal (right side).\nThis can be enabled during the mission. To disable it, the mission needs to be restarted.</English>
            <French>Lorsque cette option est activée, elle crée un onglet « Immersion Cig » dans l'arsenal ACE (côté droit). Pour le désactiver, la mission doit être redémarrée.</French>
            <Japanese>有効化するとImmersion CigカテゴリがACE武器庫に追加されます(右側の列)。\nこれはミッション中でも有効化できますが、無効化にはリスタートが必要です。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_cough_modifier">
            <English>Coughing Modifier</English>
            <French>Modificateur de toux</French>
            <Japanese>咳込みの頻度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_cough_modifier_desc">
            <English>Defines how likely it is for a smoker to cough.\n0% disables the feature.</English>
            <French>Définit la probabilité qu'un fumeur tousse.\n0 % désactive cette fonctionnalité.</French>
            <Japanese>喫煙者がどのくらいの頻度で咳き込むかを定義します。\n0%で機能を無効化。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_decrease_delay">
            <English>Fatigue Decrease Delay</English>
            <French>Réduction du retard lié à la fatigue</French>
            <Japanese>ファティーグ低下の遅延</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_decrease_delay_desc">
            <English>Defines the delay before the smoking penalty will start to wear off.\nin Minutes.</English>
            <French>Définit le délai avant que la pénalité pour avoir fumé commence à s'estomper.\En minutes.</French>
            <Japanese>喫煙者が何分後にファティーグ(スタミナ)低下ペナルティが終了し始めるかを調整します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_enabled">
            <English>Enable Adv. Fatigue Integration</English>
            <French>Activer l'intégration avancée de la fatigue</French>
            <Japanese>高度な疲労(ファティーグ)の統合</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_enabled_desc">
            <English>When Enabled, smoking will affect ACE Advanced Fatigue System.</English>
            <French>Lorsque cette option est activée, le tabagisme aura une incidence sur le système avancé de fatigue ACE.</French>
            <Japanese>有効化するとACE高度な疲労(ファティーグ)システムに影響するようになります。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_modifier">
            <English>Fatigue Modifier</English>
            <French>Modificateur de fatigue</French>
            <Japanese>ファティーグ調整</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_adv_fatigue_modifier_desc">
            <English>Defines how strong smoking will be taken into account for the fatigue impact.</English>
            <French>Définit dans quelle mesure le tabagisme sera pris en compte dans l'impact de la fatigue.</French>
            <Japanese>喫煙がどのくらいファティーグ(疲労・スタミナ低下)へ影響を及ぼすかを定義します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_effect_combustion_chance">
            <English>Chance of Spontaneous Combustion</English>
            <French>Risque de combustion spontanée</French>
            <Japanese>自然発火の可能性</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_effect_combustion_chance_desc">
            <English>Defines the chance at which a player/unit might start burning if they're doing something silly and/or risky while smoking.\n 0% disables the effect.</English>
            <French>Définit le risque qu'un joueur ou une unité commence à brûler s'il fait quelque chose de stupide et/ou de risqué en fumant.</French>
            <Japanese>プレイヤーが喫煙中に危険や愚かな行動をしたときにタバコの火が原因で体に着火する可能性を定義します。/n0%で機能を無効化。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_effect_smoke_particles">
            <English>Amount of smoke particles</English>
            <French>Risque de combustion spontanée</French>
            <Japanese>パーティクルの量</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_effect_smoke_particles_desc">
            <English>Defines the amount of smoke particles dropped when a person is smoking. Client side setting.</English>
            <French>Définit la quantité de particules de fumée rejetées lorsqu'une personne fume. Réglage côté client.</French>
            <Japanese>喫煙時にユニットから発生するパーティクルの量を定義します。クライアント側設定。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_require_holstered_weapon">
            <English>Holster Weapon when using Lighter</English>
            <French>Ranger l'arme dans son étui lorsque vous utilisez le briquet</French>
            <Japanese>ライター使用時に武器をしまう</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_require_holstered_weapon_desc">
            <English>When using the a lighter or matches, the player automatically holsters their gun.\nThis is required to avoid dodgy animations.</English>
            <French>Lorsqu'il utilise un briquet ou des allumettes, le joueur range automatiquement son arme dans son étui.\nCela est nécessaire pour éviter les animations douteuses.</French>
            <Japanese>ライターやマッチの使用時にプレイヤーが自動的に銃を収めます。\nこれは、不自然なアニメーションを回避するために必要です。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency">
            <English>Smoking Frequency</English>
            <French>Fréquence du tabagisme</French>
            <Japanese>吸排気の頻度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency_desc">
            <English>Defines how often you puff/draw on a smokable.</English>
            <French>Définit la fréquence à laquelle vous tirez sur un produit à fumer.</French>
            <Japanese>タバコを吸う頻度を定義します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency_entry_less">
            <English>Less Often</English>
            <French>Moins souvent</French>
            <Japanese>低頻度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency_entry_normal">
            <English>Normal</English>
            <French>Normal</French>
            <Japanese>普通</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency_entry_often">
            <English>More Often</English>
            <French>Plus souvent</French>
            <Japanese>高頻度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_frequency_entry_thomas">
            <English>Thomas</English>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity">
            <English>Smoking Intensity</English>
            <French>Intensité du tabagisme</French>
            <Japanese>吸排気の強度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity_desc">
            <English>Defines which how strong/long you puff/draw a smokable.</English>
            <French>Définit la force/durée avec laquelle vous tirez sur un produit à fumer.</French>
            <Japanese>タバコをどれくらいの強さで、どれくらいの時間吸い込むかを定義します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity_entry_thomas">
            <English>Thomas</English>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity_entry_long">
            <English>More Intensive</English>
            <French>Plus intensif</French>
            <Japanese>低強度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity_entry_normal">
            <English>Normal</English>
            <French>Normal</French>
            <Japanese>普通</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_smoking_intensity_entry_short">
            <English>Less Intensive</English>
            <French>Moins intensif</French>
            <Japanese>高強度</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addCigpack">
            <English>Start with a CigPack</English>
            <French>Commencer avec un CigPack</French>
            <Japanese>タバコを所持した状態で開始</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addCigpack_desc">
            <English>Adds a CigPack the beginning of a single player mission.</English>
            <French>Ajoute un CigPack au début d'une mission singleplayer.</French>
            <Japanese>シングルプレイヤーミッションの開始時にタバコの箱を追加します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addCigpack_type">
            <English>Type of Pack</English>
            <French>Type d'emballage</French>
            <Japanese>タバコの種類</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addCigpack_type_desc">
            <English>Defines which type of CigPack (or other) will be added at the beginning of a single player mission.</English>
            <French>Définit le type de CigPack (ou autre) qui sera ajouté au début d'une mission singleplayer.</French>
            <Japanese>シングルプレイヤーミッションの開始時に追加されるタバコの箱（またはその他のアイテム）の種類を定義します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addItems">
            <English>Add Items to Player in SP</English>
            <French>Ajouter des éléments au joueur dans le SP</French>
            <Japanese>シングルプレイヤーでアイテム追加</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addItems_desc">
            <English>When this is enabled, the following items will be added in single player to the players inventory.</English>
            <French>Lorsque cette option est activée, les objets suivants sont ajoutés à l'inventaire du joueur en mode solo.</French>
            <Japanese>有効化するとシングルプレイヤーでこれらのアイテムがプレイヤーのインベントリに追加されます。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addLighter">
            <English>Start with a Lighter</English>
            <French>Commencer avec un briquet</French>
            <Japanese>ライターを所持した状態で開始</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addLighter_desc">
            <English>Adds a Lighter at the beginning of a single player mission.</English>
            <French>Ajoute un briquet au début d'une mission (SP seulement).</French>
            <Japanese>シングルプレイヤーミッションの開始時にライターを追加します。</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addLighter_type">
            <English>Type of Lighter</English>
            <French>Type de briquet</French>
            <Japanese>ライターの種類</Japanese>
        </Key>
        <Key ID="STR_cigs_core_set_sp_addLighter_type_desc">
            <English>Defines which type of lighter will be added at the beginning of a single player mission.</English>
            <French>Définit le type de briquet qui sera ajouté au début d'une mission (SP seulement).</French>
            <Japanese>シングルプレイヤーミッションの開始時に追加されるライターの種類を定義します。</Japanese>
        </Key>
