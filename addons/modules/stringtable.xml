    <Package name="3den-categories">
        <Key ID="STR_cigs_modules_3den_category">
            <English>Immersion Cigs - Rewrite</English>
        </Key>
    </Package>
    <Package name="3den-attributes">
        <Key ID="STR_cigs_modules_blockDynamicSmoking_displayName">
            <English>Block Dynamic Smoking</English>
        </Key>
        <Key ID="STR_cigs_modules_blockDynamicSmoking_tooltip">
            <English>Will prevent adding the unit to the dynamic smoking system.\nWill only take effect when Dynamic Smoking is enabled.</English>
        </Key>

        <Key ID="STR_cigs_modules_blockcigsOnAI_displayName">
            <English>Block Cigs On AI</English>
        </Key>
        <Key ID="STR_cigs_modules_blockcigsOnAI_tooltip">
            <English>Will prevent distribution of cig-items on this unit.\nWill also prevent unit from being added to the dynamic smoking system.</English>
        </Key>

        <Key ID="STR_cigs_modules_blockAnimations_displayName">
            <English>Block Animations</English>
        </Key>
        <Key ID="STR_cigs_modules_blockAnimations_tooltip">
            <English>Will block any Immersion Cigs related animations.\nUseful for decorative Units with their own animation loop.</English>
        </Key>
    </Package>
